{
  "name": "@jobs/worker",
  "private": true,
  "scripts": {
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "once": "graphile-worker --once --concurrency 5 --task-directory ./dist/tasks -c \"$DATABASE_URL\"",
    "run": "graphile-worker --task-directory ./dist/tasks -c \"$DATABASE_URL\""
  },
  "dependencies": {
    "graphile-worker": "^0.16.4",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}


